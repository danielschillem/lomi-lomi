# --- Lomi Lomi Production Environment ---
# Copy this file to .env on the server and fill in the values

# Database
DB_USER=lomilomi
DB_PASS=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=lomilomi

# Auth (REQUIRED in production - server refuses to start without it)
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_HERE

# URLs
CORS_ORIGIN=https://texto.life
BASE_URL=https://texto.life
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=/ws

# Admin bootstrap secret
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# Orange Money payment
OM_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1
OM_API_KEY=
OM_PIN=

# Twilio SMS (for OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP (for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Firebase Admin SDK (push notifications via FCM)
# Paste the full service account JSON on a single line, wrapped in single quotes
FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"textme-7ac5d",...}'

# VAPID (web push — optional)
VAPID_PRIVATE_KEY=

# Jitsi Meet (self-hosted TextMe calls)
# JITSI_DOMAIN: sous-domaine Jitsi (doit correspondre au DNS)
JITSI_DOMAIN=meet.texto.life
# JITSI_JVB_IP: IP publique du serveur (nécessaire pour que le video bridge annonce la bonne IP aux clients)
JITSI_JVB_IP=CHANGE_ME_SERVER_PUBLIC_IP
# Mots de passe internes — générer aléatoirement (ex: openssl rand -hex 16)
JITSI_JICOFO_PASSWORD=CHANGE_ME_RANDOM_PASSWORD
JITSI_JVB_PASSWORD=CHANGE_ME_RANDOM_PASSWORD
