# --- Lomi Lomi Production Environment ---
# Copie ce fichier en .env sur le serveur et remplis les valeurs

# Database
DB_USER=lomilomi
DB_PASS=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=lomilomi

# Auth
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_HERE

# URLs (remplace par ton domaine ou IP du Droplet)
CORS_ORIGIN=https://lomilomi.app
BASE_URL=https://api.lomilomi.app
NEXT_PUBLIC_API_URL=https://api.lomilomi.app/api/v1

# Stripe (optionnel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
