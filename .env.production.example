# --- Lomi Lomi Production Environment ---
# Copy this file to .env on the server and fill in the values

# Database
DB_USER=lomilomi
DB_PASS=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=lomilomi

# Auth (REQUIRED in production - server refuses to start without it)
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_HERE

# URLs (replace with your domain or Droplet IP)
CORS_ORIGIN=http://134.209.229.141
BASE_URL=http://134.209.229.141
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=/ws

# Admin bootstrap secret
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# Orange Money payment
OM_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1
OM_API_KEY=
OM_PIN=

# Twilio SMS (for OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP (for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
