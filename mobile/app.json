{
  "expo": {
    "name": "Texto",
    "slug": "texto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "texto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lomilomi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "package": "com.lomilomi.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Texto utilise votre position pour trouver des personnes proches de vous."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Texto a besoin d'accéder à vos photos pour votre profil."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7c3aed"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://134.209.229.141/api/v1",
      "wsUrl": "ws://134.209.229.141/ws"
    }
  }
}
