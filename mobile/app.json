{
  "expo": {
    "name": "Lomi Lomi",
    "slug": "lomilomi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lomilomi",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lomilomi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "package": "com.lomilomi.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Lomi Lomi utilise votre position pour trouver des personnes proches de vous."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://138.68.66.6/api/v1",
      "wsUrl": "ws://138.68.66.6/ws"
    }
  }
}
