texto.life {
	# API backend
	handle /api/* {
		reverse_proxy backend:8888
	}

	# WebSocket
	handle /ws {
		reverse_proxy backend:8888
	}

	# Uploads statiques
	handle /uploads/* {
		reverse_proxy backend:8888
	}

	# Frontend Next.js
	handle {
		reverse_proxy frontend:3000
	}
}

# Redirection www → apex
www.texto.life {
	redir https://texto.life{uri} permanent
}

# Jitsi Meet — TextMe self-hosted video/audio calls
meet.texto.life {
	# WebSocket signaling (XMPP over WebSocket)
	handle /xmpp-websocket* {
		reverse_proxy jitsi-web:80
	}
	# BOSH fallback
	handle /http-bind* {
		reverse_proxy jitsi-web:80
	}
	# Colibri WebSocket (JVB stats/bridge)
	handle /colibri-ws* {
		reverse_proxy jitsi-web:80
	}
	# Everything else → Jitsi web interface
	handle {
		reverse_proxy jitsi-web:80
	}
}
