# Mode IP (pas de HTTPS automatique sans domaine)
# Quand tu auras un domaine, remplace :80 par ton domaine

:80 {
	# API backend — routes /api/*
	handle /api/* {
		reverse_proxy backend:8888
	}

	# WebSocket
	handle /ws {
		reverse_proxy backend:8888
	}

	# Uploads statiques
	handle /uploads/* {
		reverse_proxy backend:8888
	}

	# Tout le reste -> frontend Next.js
	handle {
		reverse_proxy frontend:3000
	}
}
