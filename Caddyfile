# 	handle /api/* {
# 		reverse_proxy backend:8888
# 	}
#
# 	# WebSocket (with proper upgrade headers)
# 	handle /ws {
# 		reverse_proxy backend:8888
# 	}
#
# 	# Static uploads
# 	handle /uploads/* {
# 		reverse_proxy backend:8888
# 	}
#
