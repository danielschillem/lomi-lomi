# Reverse proxy unique : un seul vhost qui sert IP et tout futur domaine.
# Quand un domaine sera disponible, remplacer ":80" par "your-domain.com"
# pour activer HTTPS automatique via Let's Encrypt.

:80 {
	# API backend
	handle /api/* {
		reverse_proxy backend:8888
	}

	# WebSocket
	handle /ws {
		reverse_proxy backend:8888
	}

	# Uploads statiques
	handle /uploads/* {
		reverse_proxy backend:8888
	}

	# Frontend Next.js
	handle {
		reverse_proxy frontend:3000
	}
}
