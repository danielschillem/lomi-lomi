texto.life {
	# API backend
	handle /api/* {
		reverse_proxy backend:8888
	}

	# WebSocket
	handle /ws {
		reverse_proxy backend:8888
	}

	# Uploads statiques
	handle /uploads/* {
		reverse_proxy backend:8888
	}

	# Frontend Next.js
	handle {
		reverse_proxy frontend:3000
	}
}

# Redirection www → apex
www.texto.life {
	redir https://texto.life{uri} permanent
}
