# ===== DEVELOPMENT MODE (IP, no HTTPS) =====
# When you have a domain, comment out this block and uncomment the production block below.

:80 {
	# API backend — routes /api/*
	handle /api/* {
		reverse_proxy backend:8888
	}

	# WebSocket
	handle /ws {
		reverse_proxy backend:8888
	}

	# Uploads statiques
	handle /uploads/* {
		reverse_proxy backend:8888
	}

	# Tout le reste -> frontend Next.js
	handle {
		reverse_proxy frontend:3000
	}
}

# ===== PRODUCTION MODE (uncomment and set your domain) =====
# lomilomi.app {
# 	# Automatic HTTPS via Let's Encrypt
#
